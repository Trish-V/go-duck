@Audited entity Car {
  name String required unique
  model String required
  year Integer
  price BigDecimal
  color String(50)
  features JSONB
}

entity Person {
  firstName String required
  lastName String
  email String unique
  age Integer
  preferences JSON
}

relationship OneToMany {
  Person{car} to Car{owner} required
}

open Car(read, update)
open Person(read)
