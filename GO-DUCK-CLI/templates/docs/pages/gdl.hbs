                <th class="p-3">GDL Type</th>
                <th class="p-3">Go Struct Type</th>
                <th class="p-3">Postgres / Liquibase SQL Type</th>
                <th class="p-3">GraphQL / Kratos Proto Type</th>
            </tr>
        </thead>
        <tbody class="text-sm font-light text-gray-700">
            <tr class="border-b"><td class="p-3 font-semibold">String</td><td class="p-3">string</td><td class="p-3">VARCHAR(255)</td><td class="p-3">String / string</td></tr>
            <tr class="border-b"><td class="p-3 font-semibold">String(N)</td><td class="p-3">string</td><td class="p-3">VARCHAR(N)</td><td class="p-3">String / string</td></tr>
            <tr class="border-b"><td class="p-3 font-semibold">Text</td><td class="p-3">string</td><td class="p-3">TEXT</td><td class="p-3">String / string</td></tr>
