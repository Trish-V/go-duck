    "/rpc/{table}": {
      "get": {
        "tags": [
          "Search Engine"
        ],
        "summary": "Generic PostgREST RPC Engine",
        "description": "Powerful dynamic querying system. \n            \n            ### Dynamic Filtering\n            Append any column name as a query parameter using operator notation:\n            - `?age=gt.20` (Greater Than)\n            - `?name=ilike.John` (Case-insensitive search)\n            - `?id=in.1,2,3` (Set containment)\n            \n            ### JSONB Path Querying\n            For JSON fields, use arrow notation:\n            - `?metadata->>role=eq.ADMIN` (Nested text extraction)\n            - `?details->count=gt.5` (Nested numeric extraction)",
        "parameters": [
          {
            "name": "X-Tenant-ID",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "default"
            },
            "description": "Multi-tenancy context identifier"
          },
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The database table to query"
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sorting (e.g., id.desc)"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Row limit"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Query offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
